PORT=3001
JWT_SECRET=change-me-to-a-long-random-string

# PostgreSQL connection string
# Internal (Render): postgresql://porra_admin:<pass>@<host>/<db>
# External (local dev): postgresql://porra_admin:<pass>@<host>.frankfurt-postgres.render.com:5432/<db>
DATABASE_URL=postgresql://porra_admin:CHANGE_ME@localhost:5432/porra

# Email (opcional) — si no se configura, los rechazos solo se loguean en consola
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=app-password-aqui
# SMTP_FROM=La Porra del Chat <tu@gmail.com>

# ── Scraper automático de FIFA (api.fifa.com) ────────────────────────────────
# Poner en false para desactivar el scheduler y todo el scraping de FIFA
FIFA_ENABLED=true
# 17 = FIFA World Cup. El IdSeason del Mundial 2026 se descubre solo; si falla,
# fijarlo aquí (se ve en las URLs de api.fifa.com).
FIFA_COMPETITION_ID=17
# FIFA_SEASON_ID=
# Duración estimada del partido en minutos + margen antes de scrapear el resultado
FIFA_MATCH_DURATION_MIN=105
FIFA_SCRAPE_DELAY_MIN=15
# Horas entre refrescos del calendario cuando no hay partidos en juego
FIFA_CALENDAR_REFRESH_HOURS=6

# Poner en false para deshabilitar el scraper de BeSoccer completamente
BESOCCER_ENABLED=false
# Solo si BESOCCER_ENABLED=true. Ajustar a los términos de uso de la fuente.
BESOCCER_BASE_URL=https://es.besoccer.com
BESOCCER_DELAY_MS=2000
# Fuente de datos de la FASE KO: 'fifa' (por defecto) o 'besoccer'. Con 'besoccer',
# los partidos KO con besoccer_url se scrapean de BeSoccer (en vivo + final), con
# FIFA como fallback automático. La fase de grupos siempre usa FIFA.
KO_SOURCE=fifa
